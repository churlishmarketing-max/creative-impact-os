# Copy this file to ".env.local" and paste your Supabase project values.
# Find them in the Supabase dashboard: Project Settings -> API.
# These two are safe to expose to the browser (Row Level Security protects the data).
# NEVER commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# ----------------------------------------------------------------------------
# Phase 2 — payments (Invoices). Optional: invoices work without these, but the
# client "Pay" button only activates once they're set. These are SERVER-ONLY
# secrets — never prefix them with NEXT_PUBLIC, and add them in Vercel as well.
# ----------------------------------------------------------------------------
# Stripe -> Developers -> API keys (use your LIVE secret key when ready):
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# Supabase -> Project Settings -> API -> service_role (secret) key. Lets the
# server mark an invoice paid after Stripe confirms. Keep this private.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ----------------------------------------------------------------------------
# Phase 5 — Facebook lead import (optional, set up with guidance). Server-only.
# Also requires SUPABASE_SERVICE_ROLE_KEY above.
# ----------------------------------------------------------------------------
# FB_VERIFY_TOKEN=any-random-string-you-choose (you'll paste the same one into Meta)
# FB_APP_SECRET=from Meta -> App settings -> Basic -> App Secret
# FB_PAGE_ACCESS_TOKEN=long-lived Page access token for your Facebook Page

# ----------------------------------------------------------------------------
# Email notifications (bookings + signed proposals). Server-only.
# ----------------------------------------------------------------------------
# RESEND_API_KEY=re_... (from resend.com -> API Keys)
# Verify churlishos.app in Resend (the one free-tier domain) and send from it:
# EMAIL_FROM=Churlish Media <hello@churlishos.app>
# EMAIL_BCC=hello@churlishmedia.com   (your Gmail copy of notifications + client replies — a recipient, costs nothing)

# Client email threads (CRM send/receive). Replies route to the Resend Inbound
# address; each reply is filed to the client's thread AND forwarded to EMAIL_BCC:
# EMAIL_REPLY_TO=crm@in.churlishos.app
# RESEND_WEBHOOK_SECRET=whsec_...   (from the Resend webhook for email.received)

# Agent layer (Pennyworth drafting). Server-only.
# ANTHROPIC_API_KEY=sk-ant-...      (console.anthropic.com -> API Keys)
# AGENT_MODEL=claude-sonnet-5       (optional override)

# ----------------------------------------------------------------------------
# Automations (daily cron: onboarding nudges, stall alerts, referral sequence).
# Server-only. Vercel Cron calls /api/cron/daily once a day and automatically
# sends CRON_SECRET as a Bearer token once the env var exists in Vercel.
# ----------------------------------------------------------------------------
# CRON_SECRET=any-long-random-string
# REFERRAL_TARGET_URL=https://churlishmedia.com   (where /r/<code> links land)

# ----------------------------------------------------------------------------
# Android app (TWA). After PWABuilder signs your APK, paste the SHA-256
# fingerprint it reports here — it's served at /.well-known/assetlinks.json
# and is what removes the URL bar from the installed app.
# ----------------------------------------------------------------------------
# ASSETLINKS_SHA256=AA:BB:CC:...
# ANDROID_PACKAGE_ID=com.churlishmedia.os   (only if you change the default)
